{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "rootDir": "./src",
    "types": ["node", "jasmine"], // Add jasmine here
    "allowJs": true,
    "moduleResolution": "bundler",
    "ignoreDeprecations": "5.0"
  },
  "files": ["src/main.ts"],
  "include": ["src/**/*.d.ts", "src/**/*.ts"]
}